# Workspace root directory (all file operations restricted to this path)
WORKSPACE_ROOT=/github

# Server
PORT=3000
# Bind address. 127.0.0.1 = loopback only (safest, use with Cloudflare tunnel).
# Use 0.0.0.0 ONLY if you want to expose the server on your LAN — then you
# MUST set PUBLIC_ORIGINS below, otherwise CORS will reject browser clients.
HOST=127.0.0.1

# Comma-separated list of public origins allowed by CORS (in addition to localhost).
# Set this to your tunnel / custom domain when exposing the server publicly.
# Example: PUBLIC_ORIGINS=https://myapp.trycloudflare.com,https://projectx.mydomain.com
PUBLIC_ORIGINS=

# JWT — generate a strong random secret with:  openssl rand -hex 32
# (minimum 32 chars, the server will refuse to start otherwise)
JWT_SECRET=
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# Auth credentials (run `npm run setup` to generate hashed password)
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=

# Claude API (fallback when CLI unavailable)
ANTHROPIC_API_KEY=

# Rate limiting
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW=300000

# File watcher debounce (ms)
WATCHER_DEBOUNCE=500

# Optional supply-chain pin for the cloudflared binary.
# Comma-separated list of lowercase SHA256 hashes (from Cloudflare's release page)
# that the local cloudflared must match. If empty, the server just LOGS the
# detected hash on each tunnel start so you can verify it manually.
# If set, the server will refuse to start the tunnel unless the binary hash matches.
# Example: CLOUDFLARED_EXPECTED_SHA256=abc123...,def456...
CLOUDFLARED_EXPECTED_SHA256=
